{
  "name": "smoketape",
  "version": "0.1.0",
  "description": "Local-first YAML smoke tapes for CLI proof reports.",
  "type": "module",
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "docs",
    "fixtures",
    "reports",
    "scripts",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "RELEASE_NOTES.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "smoke-test",
    "yaml",
    "local-first",
    "testing"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "types": "./dist/src/index.d.ts",
  "bin": {
    "smoketape": "./dist/src/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/smoketape.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/smoketape/issues"
  },
  "homepage": "https://github.com/rogerchappel/smoketape#readme"
}
